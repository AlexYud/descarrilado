[node name="Flashlight" parent="SceneStructure/JulianasHouse/Furniture" unique_id=164557964 instance=ExtResource("7_bjd11")]
transform = Transform3D(-0.8146565, 0.5779946, 0.04750724, -0.034481864, 0.033497605, -0.9988438, -0.5789176, -0.8153528, -0.007358712, -5.0316634, 0.37844515, 4.2973175)
item_name = "Lanterna de plantão"
item_description = "Lanterna grande, de corpo metálico, com tinta preta descascada perto da base. O botão de ligar afundou um pouco mais do que devia e a alça está enrolada com fita isolante para não machucar a mão. Tem três marcas de impacto numa lateral, como se já tivesse caído no cascalho mais de uma vez. Mesmo gasta, ainda passa a impressão de ser confiável."


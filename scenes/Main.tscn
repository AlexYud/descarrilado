[node name="Photo" parent="SceneStructure/JulianasHouse/Furniture/Hallway" unique_id=160603775 instance=ExtResource("5_lhr70")]
transform = Transform3D(-1, 1.7429297e-08, -8.566772e-08, 0, 0.9799247, 0.1993679, 8.742278e-08, 0.19936793, -0.9799245, -8.77214, 4.365635, 4.5680127)
inspect_name = "Foto antiga na estação"
inspect_description = "Uma foto velha, já um pouco amarelada nas bordas. Eu e Sophia ainda crianças, sentadas num banco de madeira da estação antiga. Atrás da gente aparece metade da placa do lugar e um pedaço dos trilhos. Ela está olhando direto para a câmera, sorrindo sem esforço. Eu estou meio torta na foto, com cara de quem já não gostava disso nem naquela época. A moldura é simples, de plástico escuro, com um risco comprido atravessando a frente."


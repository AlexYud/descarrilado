[node name="Medical" parent="SceneStructure/JulianasHouse/Furniture/Bedroom/Nightstand/DrawerInteractable3/DrawerRoot/ItemAnchor" parent_id_path=PackedInt32Array(248808833, 546873071) index="0" unique_id=1967662599 instance=ExtResource("4_q8u5g")]
transform = Transform3D(0.55677414, -0.8306642, 9.9055635e-09, -8.1960464e-16, 1.1924886e-08, 0.9999999, -0.83066374, -0.5567744, 6.639462e-09, -0.23917294, 0, 0.0058088303)
inspect_name = "Receita médica"
inspect_description = "Uma folha dobrada várias vezes, com a ponta rasgada e o papel já mole de tanto abrir e fechar. No topo está o nome Juliana Ferreira, a data da consulta e o carimbo da médica do posto do centro. No corpo da receita dá para ler sertralina 50 mg, uso diário, e mais abaixo uma orientação para medicação de apoio à noite, com retorno em trinta dias. Num campo digitado aparece a observação quadro de ansiedade persistente e insônia. A letra da médica no rodapé continua difícil de entender."


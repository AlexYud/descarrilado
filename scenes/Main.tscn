[node name="Newspaper" parent="SceneStructure/JulianasHouse/Furniture/Bedroom" unique_id=613955124 instance=ExtResource("10_wp0k4")]
transform = Transform3D(-0.92646295, 0.376386, 1.6452354e-08, 0, -4.371139e-08, 1, 0.376386, 0.92646295, 4.049698e-08, -4.9775004, 4.3449497, 4.2396264)
inspect_name = "Recorte de jornal"
inspect_description = "Recorte do jornal A Voz do Vale, já com a dobra marcada no meio e uma mancha de café num canto. A manchete diz “Terceira jovem desaparece em menos de dois meses na região”. A matéria cita nomes, bairros e horários, tudo escrito naquele tom apressado de jornal pequeno que quer parecer mais certo do que realmente está. Um trecho foi sublinhado de caneta azul, bem em cima da frase sobre movimentação estranha perto da linha férrea desativada."


[node name="Cellphone" parent="SceneStructure/JulianasHouse/Furniture/Bedroom" unique_id=754512920 instance=ExtResource("6_wp0k4")]
transform = Transform3D(0.115856074, -0.993266, 4.3417035e-08, 0, -4.371139e-08, -1, 0.993266, 0.115856074, -5.06423e-09, -2.8444085, 4.1851993, 2.4618084)
item_name = "Celular de Juliana"
item_description = "Capinha preta sem desenho, um canto da película rachado e marcas de unha perto do botão lateral. O aparelho está quente, como fica quando passa tempo demais na mão. Nada nele chama atenção além do desgaste de uso. É um celular comum, sem nada bonito ou novo, só funcional do jeito que precisa ser."

